# Konfigurasi Midtrans Sandbox (Ganti dengan Key Anda dari Dashboard Midtrans)
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXX

# Konfigurasi Database MySQL (Sesuai pengaturan database di aaPanel)
DB_HOST=127.0.0.1
DB_DATABASE=nama_database_vps
DB_USERNAME=username_database_vps
DB_PASSWORD=password_database_vps
